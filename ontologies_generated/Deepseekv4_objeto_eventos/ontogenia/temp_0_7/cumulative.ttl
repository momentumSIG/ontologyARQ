# ==================== DATA PROPERTIES =====================
arqo:hasLengthValue a owl:DatatypeProperty ;
    rdfs:domain arqo:MeasurementEvent ;
    rdfs:range xsd:decimal ;
    rdfs:label "hasLengthValue"@en .

arqo:hasWeightValue a owl:DatatypeProperty ;
    rdfs:domain arqo:MeasurementEvent ;
    rdfs:range xsd:decimal ;
    rdfs:label "hasWeightValue"@en .

