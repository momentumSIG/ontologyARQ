@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix crmarchaeo: <http://www.cidoc-crm.org/crmarchaeo/> .
@prefix crmsci: <http://www.cidoc-crm.org/crmsci/> .
@prefix crmhs: <http://www.cidoc-crm.org/crmhs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .


# ============================================================
# Ontology: Archaeological Object Module (K2.6 Design)
# Model: K2.6 | Strategy: memoryless | Temperature: 0.5
# CQ: OBJ-05
# Design: Object-centric with deep taxonomic hierarchy
# ============================================================

# ======================= CLASSES ===========================
arqo:ArchaeologicalObject a owl:Class ;
    rdfs:subClassOf crm:E19_Physical_Object ;
    rdfs:label "ArchaeologicalObject"@en ;
    rdfs:comment "Root class for all archaeological objects"@en .

arqo:MorphometricAttribute a owl:Class ;
    rdfs:subClassOf crm:E54_Dimension ;
    rdfs:label "MorphometricAttribute"@en ;
    rdfs:comment "Morphometric attribute (dimension, weight)"@en .

# =================== OBJECT PROPERTIES =====================
arqo:hasMorphometricAttribute a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:MorphometricAttribute ;
    rdfs:label "hasMorphometricAttribute"@en ;
    rdfs:comment "Morphometric dimension or weight"@en .

# ==================== DATA PROPERTIES =====================
arqo:hasWeight a owl:DatatypeProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range xsd:decimal ;
    rdfs:label "hasWeight"@en ;
    rdfs:comment "Weight of the object in grams"@en .

arqo:hasLength a owl:DatatypeProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range xsd:decimal ;
    rdfs:label "hasLength"@en ;
    rdfs:comment "Length dimension"@en .

arqo:hasWidth a owl:DatatypeProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range xsd:decimal ;
    rdfs:label "hasWidth"@en ;
    rdfs:comment "Width dimension"@en .

arqo:hasHeight a owl:DatatypeProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range xsd:decimal ;
    rdfs:label "hasHeight"@en ;
    rdfs:comment "Height dimension"@en .

# ===================== RESTRICTIONS =======================
arqo:ArchaeologicalObject rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty arqo:hasRawMaterial ;
    owl:someValuesFrom crm:E57_Material
] .

# Ontology generated by K2.6 using memoryless strategy at temperature 0.5
# Compatible with CIDOC CRM v7.3.2 and CRMarchaeo v2.1.1
