# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: memoryless
# Temperature: 0.5
# CQ: OBJ-16
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix crmarchaeo: <http://www.cidoc-crm.org/crmarchaeo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

arqo:DepositionEvent a owl:Class ;
    rdfs:subClassOf crmarchaeo:A4_Stratigraphic_Genesis ;
    rdfs:label "DepositionEvent"@en ;
    rdfs:comment "Event of an object entering the archaeological record"@en .

arqo:IntentionalDepositionEvent a owl:Class ;
    rdfs:subClassOf arqo:DepositionEvent ;
    rdfs:label "IntentionalDepositionEvent"@en ;
    rdfs:comment "Ritual, burial, or deliberate discard"@en .

arqo:AccidentalDepositionEvent a owl:Class ;
    rdfs:subClassOf arqo:DepositionEvent ;
    rdfs:label "AccidentalDepositionEvent"@en ;
    rdfs:comment "Loss, abandonment, or accidental discard"@en .

arqo:hasDepositionIntentionality a owl:DatatypeProperty ;
    rdfs:domain arqo:DepositionEvent ;
    rdfs:range xsd:string ;
    rdfs:label "has deposition intentionality"@en .

arqo:depositedObject a owl:ObjectProperty ;
    rdfs:domain arqo:DepositionEvent ;
    rdfs:range crm:E19_Physical_Object ;
    rdfs:label "deposited object"@en .

arqo:depositedInUnit a owl:ObjectProperty ;
    rdfs:domain arqo:DepositionEvent ;
    rdfs:range crmarchaeo:A8_Stratigraphic_Unit ;
    rdfs:label "deposited in stratigraphic unit"@en .
