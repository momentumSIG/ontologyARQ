# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: memoryless
# Temperature: 0.7
# CQ: OBJ-21
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix crmsci: <http://www.cidoc-crm.org/crmsci/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

arqo:AnalyticalEncounterEvent a owl:Class ;
    rdfs:subClassOf crmsci:S19_Encounter ;
    rdfs:label "AnalyticalEncounterEvent"@en .

arqo:NonInvasiveAnalysisEvent a owl:Class ;
    rdfs:subClassOf arqo:AnalyticalEncounterEvent ;
    rdfs:label "NonInvasiveAnalysisEvent"@en .

arqo:MicroDestructiveAnalysisEvent a owl:Class ;
    rdfs:subClassOf arqo:AnalyticalEncounterEvent ;
    rdfs:label "MicroDestructiveAnalysisEvent"@en .

arqo:SpectroscopicAnalysisEvent a owl:Class ;
    rdfs:subClassOf arqo:NonInvasiveAnalysisEvent ;
    rdfs:label "SpectroscopicAnalysisEvent"@en .

arqo:hasAnalyticalTechnique a owl:DatatypeProperty ;
    rdfs:domain arqo:AnalyticalEncounterEvent ;
    rdfs:range xsd:string ;
    rdfs:label "has analytical technique"@en .

arqo:analyzedObject a owl:ObjectProperty ;
    rdfs:domain arqo:AnalyticalEncounterEvent ;
    rdfs:range crm:E19_Physical_Object ;
    rdfs:label "analyzed object"@en .

arqo:resultedInMaterialAssignment a owl:ObjectProperty ;
    rdfs:domain arqo:AnalyticalEncounterEvent ;
    rdfs:range crm:E17_Type_Assignment ;
    rdfs:label "resulted in material assignment"@en .

arqo:hasAnalysisDate a owl:DatatypeProperty ;
    rdfs:domain arqo:AnalyticalEncounterEvent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "has analysis date"@en .

# Disjointness
arqo:NonInvasiveAnalysisEvent owl:disjointWith arqo:MicroDestructiveAnalysisEvent .
