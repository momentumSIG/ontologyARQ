# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: memoryless
# Temperature: 0.7
# CQ: OBJ-26
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

arqo:ConservationTreatmentEvent a owl:Class ;
    rdfs:subClassOf crm:E7_Activity ;
    rdfs:label "ConservationTreatmentEvent"@en .

arqo:ConservationDecisionEvent a owl:Class ;
    rdfs:subClassOf crm:E5_Event ;
    rdfs:label "ConservationDecisionEvent"@en .

arqo:StakeholderConsultationEvent a owl:Class ;
    rdfs:subClassOf arqo:ConservationDecisionEvent ;
    rdfs:label "StakeholderConsultationEvent"@en .

arqo:RiskAssessmentEvent a owl:Class ;
    rdfs:subClassOf arqo:ConservationDecisionEvent ;
    rdfs:label "RiskAssessmentEvent"@en .

arqo:EthicalReviewEvent a owl:Class ;
    rdfs:subClassOf arqo:ConservationDecisionEvent ;
    rdfs:label "EthicalReviewEvent"@en .

arqo:precededByDecision a owl:ObjectProperty ;
    rdfs:domain arqo:ConservationTreatmentEvent ;
    rdfs:range arqo:ConservationDecisionEvent ;
    rdfs:label "preceded by decision"@en .

arqo:hasStakeholderValue a owl:DatatypeProperty ;
    rdfs:domain arqo:StakeholderConsultationEvent ;
    rdfs:range xsd:string ;
    rdfs:label "has stakeholder value"@en .

arqo:hasRiskAssessment a owl:DatatypeProperty ;
    rdfs:domain arqo:RiskAssessmentEvent ;
    rdfs:range xsd:string ;
    rdfs:label "has risk assessment"@en .

arqo:treatedObject a owl:ObjectProperty ;
    rdfs:domain arqo:ConservationTreatmentEvent ;
    rdfs:range crm:E19_Physical_Object ;
    rdfs:label "treated object"@en .

# Disjointness
arqo:StakeholderConsultationEvent owl:disjointWith arqo:RiskAssessmentEvent .
