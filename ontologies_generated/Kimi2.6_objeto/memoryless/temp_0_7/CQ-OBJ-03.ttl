# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: memoryless
# Temperature: 0.7
# CQ: OBJ-03
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

arqo:ManufacturingEvent a owl:Class ;
    rdfs:subClassOf crm:E12_Production ;
    rdfs:label "ManufacturingEvent"@en .

arqo:ChaineOperatoire a owl:Class ;
    rdfs:subClassOf crm:E29_Design_or_Procedure ;
    rdfs:label "ChaineOperatoire"@en .

arqo:AmbiguousManufacturingEvent a owl:Class ;
    rdfs:subClassOf arqo:ManufacturingEvent ;
    rdfs:label "AmbiguousManufacturingEvent"@en ;
    rdfs:comment "Manufacturing event producing objects whose nature/culture status is ambiguous"@en .

arqo:employedChaineOperatoire a owl:ObjectProperty ;
    rdfs:domain arqo:ManufacturingEvent ;
    rdfs:range arqo:ChaineOperatoire ;
    rdfs:label "employed chaine operatoire"@en .

arqo:producedHumanMadeObject a owl:ObjectProperty ;
    rdfs:domain arqo:ManufacturingEvent ;
    rdfs:range crm:E22_Human-Made_Object ;
    rdfs:label "produced human-made object"@en .

arqo:producedNaturalObject a owl:ObjectProperty ;
    rdfs:domain arqo:ManufacturingEvent ;
    rdfs:range crm:E19_Physical_Object ;
    rdfs:label "produced natural object"@en .

arqo:hasAmbiguousOrigin a owl:DatatypeProperty ;
    rdfs:domain arqo:AmbiguousManufacturingEvent ;
    rdfs:range xsd:boolean ;
    rdfs:label "has ambiguous origin"@en .

# Restrictions
arqo:AmbiguousManufacturingEvent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty arqo:producedHumanMadeObject ;
    owl:minCardinality 1
] , [
    a owl:Restriction ;
    owl:onProperty arqo:producedNaturalObject ;
    owl:minCardinality 1
] .
