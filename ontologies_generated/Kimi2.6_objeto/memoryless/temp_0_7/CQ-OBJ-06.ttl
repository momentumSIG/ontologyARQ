# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: memoryless
# Temperature: 0.7
# CQ: OBJ-06
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

arqo:UseEvent a owl:Class ;
    rdfs:subClassOf crm:E7_Activity ;
    rdfs:label "UseEvent"@en .

arqo:PrimaryUseEvent a owl:Class ;
    rdfs:subClassOf arqo:UseEvent ;
    rdfs:label "PrimaryUseEvent"@en .

arqo:ExtendedUseEvent a owl:Class ;
    rdfs:subClassOf arqo:UseEvent ;
    rdfs:label "ExtendedUseEvent"@en ;
    rdfs:comment "Use beyond the manufacturing date range of the typological class"@en .

arqo:RitualUseEvent a owl:Class ;
    rdfs:subClassOf arqo:UseEvent ;
    rdfs:label "RitualUseEvent"@en .

arqo:hasFunctionalRole a owl:ObjectProperty ;
    rdfs:domain arqo:UseEvent ;
    rdfs:range crm:E55_Type ;
    rdfs:label "has functional role"@en .

arqo:hasUseDateStart a owl:DatatypeProperty ;
    rdfs:domain arqo:UseEvent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "has use date start"@en .

arqo:hasUseDateEnd a owl:DatatypeProperty ;
    rdfs:domain arqo:UseEvent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "has use date end"@en .

arqo:extendsBeyondTypeRange a owl:DatatypeProperty ;
    rdfs:domain arqo:ExtendedUseEvent ;
    rdfs:range xsd:boolean ;
    rdfs:label "extends beyond type range"@en .

# Disjointness
arqo:PrimaryUseEvent owl:disjointWith arqo:RitualUseEvent .

# Restrictions
arqo:ExtendedUseEvent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty arqo:extendsBeyondTypeRange ;
    owl:hasValue true
] .
