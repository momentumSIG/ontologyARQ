# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: memoryless
# Temperature: 0.7
# CQ: OBJ-28
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix crminf: <http://www.cidoc-crm.org/crminf/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

arqo:ObjectBiographyEvent a owl:Class ;
    rdfs:subClassOf crminf:I4_Proposition_Set ;
    rdfs:label "ObjectBiographyEvent"@en .

arqo:ObjectLifecycleEvent a owl:Class ;
    rdfs:subClassOf crm:E5_Event ;
    rdfs:label "ObjectLifecycleEvent"@en .

arqo:CompetingBiographyEvent a owl:Class ;
    rdfs:subClassOf arqo:ObjectBiographyEvent ;
    rdfs:label "CompetingBiographyEvent"@en ;
    rdfs:comment "A biography that contradicts another biography for the same object"@en .

arqo:toldByInterpreter a owl:ObjectProperty ;
    rdfs:domain arqo:ObjectBiographyEvent ;
    rdfs:range crm:E39_Actor ;
    rdfs:label "told by interpreter"@en .

arqo:hasNarrativeFocus a owl:DatatypeProperty ;
    rdfs:domain arqo:ObjectBiographyEvent ;
    rdfs:range xsd:string ;
    rdfs:label "has narrative focus"@en .

arqo:differsFromLifecycle a owl:ObjectProperty ;
    rdfs:domain arqo:ObjectBiographyEvent ;
    rdfs:range arqo:ObjectLifecycleEvent ;
    rdfs:label "differs from lifecycle"@en .

arqo:contradictsBiography a owl:ObjectProperty ;
    rdfs:domain arqo:CompetingBiographyEvent ;
    rdfs:range arqo:ObjectBiographyEvent ;
    rdfs:label "contradicts biography"@en .

# Restrictions
arqo:CompetingBiographyEvent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty arqo:contradictsBiography ;
    owl:minCardinality 1
] .
