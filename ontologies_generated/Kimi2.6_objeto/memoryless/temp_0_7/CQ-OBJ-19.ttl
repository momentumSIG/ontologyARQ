# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: memoryless
# Temperature: 0.7
# CQ: OBJ-19
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix crmarchaeo: <http://www.cidoc-crm.org/crmarchaeo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

arqo:RecoveryEvent a owl:Class ;
    rdfs:subClassOf crmarchaeo:A1_Excavation_Process_Unit ;
    rdfs:label "RecoveryEvent"@en .

arqo:SystematicExcavationEvent a owl:Class ;
    rdfs:subClassOf arqo:RecoveryEvent ;
    rdfs:label "SystematicExcavationEvent"@en .

arqo:RescueRecoveryEvent a owl:Class ;
    rdfs:subClassOf arqo:RecoveryEvent ;
    rdfs:label "RescueRecoveryEvent"@en .

arqo:recoveredObject a owl:ObjectProperty ;
    rdfs:domain arqo:RecoveryEvent ;
    rdfs:range crm:E19_Physical_Object ;
    rdfs:label "recovered object"@en .

arqo:recoveryInUnit a owl:ObjectProperty ;
    rdfs:domain arqo:RecoveryEvent ;
    rdfs:range crmarchaeo:A8_Stratigraphic_Unit ;
    rdfs:label "recovery in stratigraphic unit"@en .

arqo:hasRecoveryDate a owl:DatatypeProperty ;
    rdfs:domain arqo:RecoveryEvent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "has recovery date"@en .

arqo:conductedBy a owl:ObjectProperty ;
    rdfs:domain arqo:RecoveryEvent ;
    rdfs:range crm:E39_Actor ;
    rdfs:label "conducted by"@en .

arqo:recoveryMethod a owl:DatatypeProperty ;
    rdfs:domain arqo:RecoveryEvent ;
    rdfs:range xsd:string ;
    rdfs:label "recovery method"@en .

# Disjointness
arqo:SystematicExcavationEvent owl:disjointWith arqo:RescueRecoveryEvent .
