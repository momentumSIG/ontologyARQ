# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: memoryless
# Temperature: 0.7
# CQ: OBJ-24
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

arqo:TerminusPostQuemEvent a owl:Class ;
    rdfs:subClassOf crm:E5_Event ;
    rdfs:label "TerminusPostQuemEvent"@en .

arqo:TerminusAnteQuemEvent a owl:Class ;
    rdfs:subClassOf crm:E5_Event ;
    rdfs:label "TerminusAnteQuemEvent"@en .

arqo:ChronologicalBoundaryEvent a owl:Class ;
    rdfs:subClassOf crm:E52_Time-Span ;
    rdfs:label "ChronologicalBoundaryEvent"@en ;
    rdfs:comment "The temporal interval bounded by TPQ and TAQ events"@en .

arqo:hasTPQDate a owl:DatatypeProperty ;
    rdfs:domain arqo:TerminusPostQuemEvent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "has TPQ date"@en .

arqo:hasTAQDate a owl:DatatypeProperty ;
    rdfs:domain arqo:TerminusAnteQuemEvent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "has TAQ date"@en .

arqo:establishesBoundaryFor a owl:ObjectProperty ;
    rdfs:domain arqo:TerminusPostQuemEvent ;
    rdfs:range arqo:ChronologicalBoundaryEvent ;
    rdfs:label "establishes boundary for"@en .

arqo:relatesToManufacturingEvent a owl:ObjectProperty ;
    rdfs:domain arqo:TerminusPostQuemEvent ;
    rdfs:range crm:E12_Production ;
    rdfs:label "relates to manufacturing event"@en .

arqo:relatesToUseEvent a owl:ObjectProperty ;
    rdfs:domain arqo:TerminusPostQuemEvent ;
    rdfs:range crm:E7_Activity ;
    rdfs:label "relates to use event"@en .

arqo:relatesToDepositionEvent a owl:ObjectProperty ;
    rdfs:domain arqo:TerminusPostQuemEvent ;
    rdfs:range crm:E5_Event ;
    rdfs:label "relates to deposition event"@en .

# Disjointness
arqo:TerminusPostQuemEvent owl:disjointWith arqo:TerminusAnteQuemEvent .
