# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: memoryless
# Temperature: 0.7
# CQ: OBJ-27
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

arqo:TypologicalAssignmentEvent a owl:Class ;
    rdfs:subClassOf crm:E17_Type_Assignment ;
    rdfs:label "TypologicalAssignmentEvent"@en .

arqo:DiagnosticCriteria a owl:Class ;
    rdfs:subClassOf crm:E55_Type ;
    rdfs:label "DiagnosticCriteria"@en .

arqo:MorphologicalCriterion a owl:Class ;
    rdfs:subClassOf arqo:DiagnosticCriteria ;
    rdfs:label "MorphologicalCriterion"@en .

arqo:TechnologicalCriterion a owl:Class ;
    rdfs:subClassOf arqo:DiagnosticCriteria ;
    rdfs:label "TechnologicalCriterion"@en .

arqo:StylisticCriterion a owl:Class ;
    rdfs:subClassOf arqo:DiagnosticCriteria ;
    rdfs:label "StylisticCriterion"@en .

arqo:FunctionalCriterion a owl:Class ;
    rdfs:subClassOf arqo:DiagnosticCriteria ;
    rdfs:label "FunctionalCriterion"@en .

arqo:hasDiagnosticCriteria a owl:ObjectProperty ;
    rdfs:domain arqo:TypologicalAssignmentEvent ;
    rdfs:range arqo:DiagnosticCriteria ;
    rdfs:label "has diagnostic criteria"@en .

arqo:assignedByResearcher a owl:ObjectProperty ;
    rdfs:domain arqo:TypologicalAssignmentEvent ;
    rdfs:range crm:E39_Actor ;
    rdfs:label "assigned by researcher"@en .

arqo:assignedObject a owl:ObjectProperty ;
    rdfs:domain arqo:TypologicalAssignmentEvent ;
    rdfs:range crm:E19_Physical_Object ;
    rdfs:label "assigned object"@en .

arqo:hasTypologicalScheme a owl:DatatypeProperty ;
    rdfs:domain arqo:TypologicalAssignmentEvent ;
    rdfs:range xsd:string ;
    rdfs:label "has typological scheme"@en .

# Disjointness
arqo:MorphologicalCriterion owl:disjointWith arqo:StylisticCriterion .
arqo:TechnologicalCriterion owl:disjointWith arqo:FunctionalCriterion .
