# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: memoryless
# Temperature: 0.3
# CQ: OBJ-22
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix crmsci: <http://www.cidoc-crm.org/crmsci/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

arqo:ChronometricDatingEvent a owl:Class ;
    rdfs:subClassOf crmsci:S19_Encounter ;
    rdfs:label "ChronometricDatingEvent"@en ;
    rdfs:comment "Scientific event that produces an absolute date for an object or its context"@en .

arqo:hasDatingMethod a owl:DatatypeProperty ;
    rdfs:domain arqo:ChronometricDatingEvent ;
    rdfs:range xsd:string ;
    rdfs:label "has dating method"@en ;
    rdfs:comment "Method: radiocarbon, U-series, K-Ar, Ar-Ar, TL, OSL"@en .

arqo:hasCalibratedAgeInterval a owl:DatatypeProperty ;
    rdfs:domain arqo:ChronometricDatingEvent ;
    rdfs:range xsd:string ;
    rdfs:label "has calibrated age interval"@en .

arqo:hasUncertaintyRange a owl:DatatypeProperty ;
    rdfs:domain arqo:ChronometricDatingEvent ;
    rdfs:range xsd:string ;
    rdfs:label "has uncertainty range"@en .

arqo:datedObject a owl:ObjectProperty ;
    rdfs:domain arqo:ChronometricDatingEvent ;
    rdfs:range crm:E19_Physical_Object ;
    rdfs:label "dated object"@en .
