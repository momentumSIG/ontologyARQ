# ============================================================
# Ontology: Archaeological Object Module
# Model: Kimi-2.6
# Strategy: ontogenia
# Temperature: 0.3
# CQ: OBJ-04
# Step: 4/30
# Design: Event-centric
# ============================================================

@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix crmarchaeo: <http://www.cidoc-crm.org/crmarchaeo/> .
@prefix crmsci: <http://www.cidoc-crm.org/crmsci/> .
@prefix crminf: <http://www.cidoc-crm.org/crminf/> .
@prefix crmhs: <http://www.cidoc-crm.org/crmhs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

arqo:ManufacturingEvent a owl:Class ;
    rdfs:subClassOf crm:E12_Production ;
    rdfs:label "ManufacturingEvent"@en ;
    rdfs:comment "Event of object production through specific technological procedures"@en .

arqo:employedChaineOperatoire a owl:ObjectProperty ;
    rdfs:domain arqo:ManufacturingEvent ;
    rdfs:range crm:E29_Design_or_Procedure ;
    rdfs:label "employed chaine operatoire"@en ;
    rdfs:comment "Links a manufacturing event to the operational sequence of technological steps employed"@en .

arqo:producedObject a owl:ObjectProperty ;
    rdfs:domain arqo:ManufacturingEvent ;
    rdfs:range crm:E22_Human-Made_Object ;
    rdfs:label "produced object"@en ;
    rdfs:comment "Links a manufacturing event to the object that was produced"@en .

arqo:recoveredFromUnit a owl:ObjectProperty ;
    rdfs:domain crm:E19_Physical_Object ;
    rdfs:range crmarchaeo:A8_Stratigraphic_Unit ;
    rdfs:label "recovered from stratigraphic unit"@en .
arqo:RawMaterialExtractionEvent a owl:Class ;
    rdfs:subClassOf crm:E7_Activity ;
    rdfs:label "RawMaterialExtractionEvent"@en ;
    rdfs:comment "Event of extracting raw materials from a geological source"@en .

arqo:suppliedMaterialFor a owl:ObjectProperty ;
    rdfs:domain arqo:RawMaterialExtractionEvent ;
    rdfs:range crm:E12_Production ;
    rdfs:label "supplied material for"@en ;
    rdfs:comment "Links a raw material extraction event to the manufacturing event that used the extracted material"@en .

arqo:extractedFromSource a owl:ObjectProperty ;
    rdfs:domain arqo:RawMaterialExtractionEvent ;
    rdfs:range crm:E53_Place ;
    rdfs:label "extracted from source"@en ;
    rdfs:comment "Links an extraction event to the geographic or geological source"@en .

arqo:extractedMaterial a owl:ObjectProperty ;
    rdfs:domain arqo:RawMaterialExtractionEvent ;
    rdfs:range crm:E57_Material ;
    rdfs:label "extracted material"@en .
arqo:ManufacturingEvent a owl:Class ;
    rdfs:subClassOf crm:E12_Production ;
    rdfs:label "ManufacturingEvent"@en .

arqo:employedChaineOperatoire a owl:ObjectProperty ;
    rdfs:domain arqo:ManufacturingEvent ;
    rdfs:range crm:E29_Design_or_Procedure ;
    rdfs:label "employed chaine operatoire"@en .

arqo:producedHumanMadeObject a owl:ObjectProperty ;
    rdfs:domain arqo:ManufacturingEvent ;
    rdfs:range crm:E22_Human-Made_Object ;
    rdfs:label "produced human-made object"@en .

arqo:producedNaturalObject a owl:ObjectProperty ;
    rdfs:domain arqo:ManufacturingEvent ;
    rdfs:range crm:E19_Physical_Object ;
    rdfs:label "produced natural object"@en ;
    rdfs:comment "Links a manufacturing event to an object of natural origin that was selected but not substantially modified"@en .
arqo:hasManufacturingDateEnd a owl:DatatypeProperty ;
    rdfs:domain crm:E12_Production ;
    rdfs:range xsd:dateTime ;
    rdfs:label "has manufacturing date end"@en ;
    rdfs:comment "The latest date at which the object type was manufactured"@en .

arqo:hasUseDateStart a owl:DatatypeProperty ;
    rdfs:domain crm:E7_Activity ;
    rdfs:range xsd:dateTime ;
    rdfs:label "has use date start"@en ;
    rdfs:comment "The earliest date at which a specific object instance was in active use"@en .

arqo:hasTemporalGap a owl:DatatypeProperty ;
    rdfs:domain crm:E52_Time-Span ;
    rdfs:range xsd:duration ;
    rdfs:label "has temporal gap"@en ;
    rdfs:comment "The duration between the end of manufacturing and the start of use"@en .
