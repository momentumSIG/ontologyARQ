@prefix arqo: <http://www.ontologyARQ.org/archaeological-object/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix crmarchaeo: <http://www.cidoc-crm.org/crmarchaeo/> .
@prefix crmsci: <http://www.cidoc-crm.org/crmsci/> .
@prefix crmhs: <http://www.cidoc-crm.org/crmhs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .


# ============================================================
# Ontology: Archaeological Object Module
# Model: deepseek-v4-pro | Strategy: ontogenia | Temperature: 0.7
# CQ: OBJ-17
# ============================================================

# ======================= CLASSES ===========================
arqo:ArchaeologicalObject a owl:Class ;
    rdfs:subClassOf crm:E22_Human-Made_Object ;
    rdfs:label "ArchaeologicalObject"@en ;
    rdfs:comment "A physical object recovered during archaeological investigation"@en .

arqo:ObjectBiography a owl:Class ;
    rdfs:subClassOf crm:E5_Event ;
    rdfs:label "ObjectBiography"@en ;
    rdfs:comment "The complete sequence of events in an object's lifecycle"@en .

arqo:ProductionEvent a owl:Class ;
    rdfs:subClassOf crm:E12_Production ;
    rdfs:label "ProductionEvent"@en ;
    rdfs:comment "An event where an archaeological object was manufactured or created"@en .

arqo:UseEvent a owl:Class ;
    rdfs:subClassOf crm:E7_Activity ;
    rdfs:label "UseEvent"@en ;
    rdfs:comment "An event where an archaeological object was used for a purpose"@en .

arqo:DepositionEvent a owl:Class ;
    rdfs:subClassOf crmarchaeo:A4_Stratigraphic_Genesis ;
    rdfs:label "DepositionEvent"@en ;
    rdfs:comment "An event where an archaeological object was deposited in a context"@en .

arqo:RecoveryEvent a owl:Class ;
    rdfs:subClassOf crmarchaeo:A1_Excavation_Process_Unit ;
    rdfs:label "RecoveryEvent"@en ;
    rdfs:comment "An event where an archaeological object was recovered from excavation"@en .

arqo:ReuseEvent a owl:Class ;
    rdfs:subClassOf crm:E7_Activity ;
    rdfs:label "ReuseEvent"@en ;
    rdfs:comment "An event where an archaeological object was reused for a different purpose"@en .

arqo:RepairEvent a owl:Class ;
    rdfs:subClassOf crm:E81_Transformation ;
    rdfs:label "RepairEvent"@en ;
    rdfs:comment "An event where an archaeological object was repaired or modified"@en .

arqo:CirculationEvent a owl:Class ;
    rdfs:subClassOf crm:E9_Move ;
    rdfs:label "CirculationEvent"@en ;
    rdfs:comment "An event where an archaeological object moved between locations"@en .

arqo:SamplingEvent a owl:Class ;
    rdfs:subClassOf crmsci:S19_Encounter ;
    rdfs:label "SamplingEvent"@en ;
    rdfs:comment "An event where a sample was extracted from an archaeological object"@en .

arqo:TaphonomicProcess a owl:Class ;
    rdfs:subClassOf crmarchaeo:A5_Stratigraphic_Modification_Event ;
    rdfs:label "TaphonomicProcess"@en ;
    rdfs:comment "A taphonomic process affecting an archaeological object post-deposition"@en .

arqo:FunctionalTransformation a owl:Class ;
    rdfs:subClassOf crm:E81_Transformation ;
    rdfs:label "FunctionalTransformation"@en ;
    rdfs:comment "A functional transformation of an object during its use-life"@en .

arqo:ExcavationCampaign a owl:Class ;
    rdfs:subClassOf crm:E7_Activity ;
    rdfs:label "ExcavationCampaign"@en ;
    rdfs:comment "An organised excavation campaign during which objects were recovered"@en .

arqo:TypologicalAssignment a owl:Class ;
    rdfs:subClassOf crm:E17_Type_Assignment ;
    rdfs:label "TypologicalAssignment"@en ;
    rdfs:comment "Reification class assigning typological classification to an object"@en .

# arqo:ArchaeologicalObject is subclass of crm:E22_Human-Made_Object

# =================== OBJECT PROPERTIES =====================
arqo:hasMaterial a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range crm:E57_Material ;
    rdfs:label "hasMaterial"@en ;
    rdfs:comment "Indicates the material an archaeological object is made of"@en .

arqo:hasBiography a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:ObjectBiography ;
    rdfs:label "hasBiography"@en ;
    rdfs:comment "Links an archaeological object to its lifecycle biography"@en .

arqo:participatedInProduction a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:ProductionEvent ;
    rdfs:label "participatedInProduction"@en ;
    rdfs:comment "Links an object to its production event"@en .

arqo:participatedInUse a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:UseEvent ;
    rdfs:label "participatedInUse"@en ;
    rdfs:comment "Links an object to a use event it participated in"@en .

arqo:depositedIn a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range crmarchaeo:A8_Stratigraphic_Unit ;
    rdfs:label "depositedIn"@en ;
    rdfs:comment "Links an object to the stratigraphic unit where it was deposited"@en .

arqo:recoveredFrom a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range crmarchaeo:A8_Stratigraphic_Unit ;
    rdfs:label "recoveredFrom"@en ;
    rdfs:comment "Links an object to the stratigraphic unit from which it was recovered"@en .

arqo:participatedInReuse a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:ReuseEvent ;
    rdfs:label "participatedInReuse"@en ;
    rdfs:comment "Links an object to a reuse event it participated in"@en .

arqo:repairedIn a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:RepairEvent ;
    rdfs:label "repairedIn"@en ;
    rdfs:comment "Links an object to a repair event"@en .

arqo:circulatedThrough a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range crm:E53_Place ;
    rdfs:label "circulatedThrough"@en ;
    rdfs:comment "Links an object to a place it circulated through"@en .

arqo:wasSampledIn a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:SamplingEvent ;
    rdfs:label "wasSampledIn"@en ;
    rdfs:comment "Links an object to a sampling event that extracted material from it"@en .

arqo:underwentTaphonomicProcess a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:TaphonomicProcess ;
    rdfs:label "underwentTaphonomicProcess"@en ;
    rdfs:comment "Links an object to a taphonomic process that affected it"@en .

arqo:underwentTransformation a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:FunctionalTransformation ;
    rdfs:label "underwentTransformation"@en ;
    rdfs:comment "Links an object to a functional transformation event"@en .

arqo:hasTypologicalAssignment a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:TypologicalAssignment ;
    rdfs:label "hasTypologicalAssignment"@en ;
    rdfs:comment "Links an object to a typological assignment (reification)"@en .

arqo:sharesBiographyWith a owl:ObjectProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range arqo:ArchaeologicalObject ;
    rdfs:label "sharesBiographyWith"@en ;
    rdfs:comment "Links two objects that share similar biographical trajectories"@en .

# ==================== DATA PROPERTIES =====================
arqo:hasLocalIdentifier a owl:DatatypeProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range xsd:string ;
    rdfs:label "hasLocalIdentifier"@en ;
    rdfs:comment "The original local identifier of the object in the IDEArq system"@en .

arqo:hasConservationState a owl:DatatypeProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range xsd:string ;
    rdfs:label "hasConservationState"@en ;
    rdfs:comment "The conservation state description of the archaeological object"@en .

arqo:hasManufacturingTechnique a owl:DatatypeProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range xsd:string ;
    rdfs:label "hasManufacturingTechnique"@en ;
    rdfs:comment "The manufacturing technique used to produce the object"@en .

arqo:hasRawMaterialProvenance a owl:DatatypeProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range xsd:string ;
    rdfs:label "hasRawMaterialProvenance"@en ;
    rdfs:comment "The geological provenance of the raw materials"@en .

arqo:hasObjectCategory a owl:DatatypeProperty ;
    rdfs:domain arqo:ArchaeologicalObject ;
    rdfs:range xsd:string ;
    rdfs:label "hasObjectCategory"@en ;
    rdfs:comment "The category or type description of the archaeological object"@en .

# ===================== RESTRICTIONS =======================
arqo:ArchaeologicalObject rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty arqo:hasMaterial ;
    owl:someValuesFrom crm:E57_Material
] .

arqo:ArchaeologicalObject rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty arqo:hasBiography ;
    owl:allValuesFrom arqo:ObjectBiography
] .

arqo:ArchaeologicalObject rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty arqo:depositedIn ;
    owl:someValuesFrom crmarchaeo:A8_Stratigraphic_Unit
] .

arqo:RecoveryEvent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty crm:P10_falls_within ;
    owl:allValuesFrom arqo:ExcavationCampaign
] .

arqo:UseEvent owl:disjointWith arqo:ProductionEvent .

arqo:TypologicalAssignment a owl:Class ;
    rdfs:subClassOf crm:E17_Type_Assignment ;
    rdfs:label "Typological Classification Assignment"@en .

# Ontology generated by deepseek-v4-pro using ontogenia strategy at temperature 0.7
# Compatible with CIDOC CRM v7.3.2 and CRMarchaeo v2.1.1
