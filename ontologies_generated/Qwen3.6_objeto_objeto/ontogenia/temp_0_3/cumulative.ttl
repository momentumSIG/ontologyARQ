    rdfs:label "CulturalAgency"@en ;
    rdfs:comment "Cultural agency acquired by natural object through human use without physical modification"@en .

# =================== OBJECT PROPERTIES =====================
arqo:exertsCulturalAgency a owl:ObjectProperty ;
