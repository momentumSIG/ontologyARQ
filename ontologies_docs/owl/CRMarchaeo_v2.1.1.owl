    <skos:prefLabel xml:lang="en">was surface produced by</skos:prefLabel>
    <rdfs:domain rdf:resource="A10_Excavation_Interface"/>
    <rdfs:range rdf:resource="A1_Excavation_Processing_Unit"/>
    <owl:inverseOf rdf:resource="AP4_produced_surface"/>
    <rdfs:subPropertyOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/P108i_was_produced_by"/>
    <rdfs:comment xml:lang="en">Quantification of the inverse property: one to many (0,n:0,1)

