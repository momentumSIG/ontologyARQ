    <rdfs:label xml:lang="en">CRMarchaeo 2.1.1 / OWL</rdfs:label>
    <owl:versionIRI rdf:resource="http://www.cidoc-crm.org/extensions/crmarchaeo/owl/2.1.1/"/>
    <owl:imports rdf:resource="http://www.cidoc-crm.org/cidoc-crm/owl/7.1.2/"/>
